{
  "$schema" : "https:\/\/schema.linearmouse.app\/0.10.3",
  "schemes" : [
    {
      "buttons" : {
        "mappings" : [
          {
            "action" : "mouse.button.left",
            "button" : 0,
            "command" : false,
            "control" : true,
            "option" : false,
            "shift" : false
          },
          {
            "action" : "mouse.wheel.scrollDown",
            "command" : false,
            "control" : false,
            "option" : false,
            "scroll" : "down",
            "shift" : true
          },
          {
            "action" : "mouse.wheel.scrollUp",
