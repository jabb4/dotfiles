          "vertical" : true
        },
        "speed" : 0
      }
    },
    {
      "if" : {
        "device" : {
          "category" : "mouse",
          "productID" : "0xb034",
          "productName" : "MX Master 3S",
          "serialNumber" : "5110DD56",
          "vendorID" : "0x46d"
        }
      },
      "pointer" : {
        "disableAcceleration" : true
      },
      "scrolling" : {
        "acceleration" : {
          "vertical" : 1
        },
        "distance" : {
